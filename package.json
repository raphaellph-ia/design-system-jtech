{
  "name": "@sansys/design-system",
  "version": "2.2.0",
  "description": "Design System Sansys - Vue 3 Component Library with DSS Tokens",
  "type": "module",
  "main": "./dist/dss.umd.js",
  "module": "./dist/dss.es.js",
  "exports": {
    ".": {
      "import": "./dist/dss.es.js",
      "require": "./dist/dss.umd.js"
    },
    "./css": "./dist/style.css"
  },
  "files": [
    "dist",
    "components",
    "tokens",
    "utils",
    "index.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:watch": "vite build --watch",
    "build:dev": "vite build --mode development",
    "build:no-check": "vite build",
    "type-check": "vue-tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "vue": "^3.4.21",
    "vue-tsc": "^3.2.2"
  },
  "keywords": [
    "design-system",
    "vue",
    "components",
    "dss",
    "sansys",
    "tokens"
  ],
  "author": "Hebert Daniel Oliveira Chaves",
  "license": "MIT"
}
